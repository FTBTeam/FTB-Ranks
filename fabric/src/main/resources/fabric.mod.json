{
	"schemaVersion": 1,
	"id": "ftbranks",
	"version": "${version}",
	"name": "FTB Ranks",
	"description": "A simple mod that lets you create ranks for players, similar to Discord roles, and manage permissions for them",
	"authors": [
		"FTB Team"
	],
	"contact": {
		"sources": "https://github.com/FTBTeam/FTB-Ranks",
		"issues": "https://github.com/FTBTeam/FTB-Ranks/issues"
	},
	"license": "All Rights Reserved",
	"entrypoints": {
		"main": [
			"dev.ftb.mods.ftbranks.fabric.FTBRanksFabric"
		]
	},
	"depends": {
		"fabric-api": "${fabricapi_version_range}",
		"minecraft": "${minecraft_version_range_semver}",
		"ftblibrary": "${ftb_library_version_range_semver}"
	},
	"mixins": [
		"ftbranks-common.mixins.json"
	]
}
